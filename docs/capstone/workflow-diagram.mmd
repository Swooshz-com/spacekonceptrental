flowchart TD
  subgraph ingestion["RAG ingestion flow"]
    created["Google Drive: KB File Created"] --> download["Download File"]
    updated["Google Drive: KB File Updated"] --> download
    download --> loader["Text Loader"]
    loader --> splitter["Recursive Character Text Splitter"]
    splitter --> embeddings["OpenAI Embeddings"]
    embeddings --> pinecone["Pinecone namespace: SpaceKonceptRental_kb"]
    pinecone --> kbLog["Google Sheets: kb_ingestion"]
  end

  subgraph chat["Customer support chat flow"]
    user["User"] --> trigger["Chat Trigger / Webhook adaptation"]
    trigger --> normalise["Normalise Input"]
    normalise --> redact["PII Redaction"]
    redact --> dedupe["Dedup Check with preserved input"]
    dedupe --> processing["Upsert Processing by message_id"]
    processing --> agent["AI Agent"]
    agent --> tool["Pinecone Tool"]
    tool --> agent
    agent --> parse["JSON Parse"]
    parse --> reply["Reply"]
    parse --> logs["Google Sheets: conversations appendOrUpdate"]
  end

  subgraph routing["Escalation and ticket flow"]
    parse --> decision["Native IF/Set Routing"]
    decision --> leads["Google Sheets: leads"]
    decision --> tickets["Google Sheets: tickets"]
    decision --> bookings["Booking Fields"]
    decision --> unanswered["Google Sheets: unanswered_questions"]
    decision --> escalation["Escalation"]
    escalation --> gmail["Gmail Alert"]
  end

  subgraph errors["Error handler flow"]
    failure["Workflow Failure"] --> errorTrigger["Error Trigger"]
    errorTrigger --> normaliseError["Normalise Error"]
    normaliseError --> failures["Google Sheets: failures"]
    normaliseError --> alert["Gmail Alert"]
  end
