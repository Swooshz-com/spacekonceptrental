      "parameters": {
        "jsCode": "const metadataItems = $items('Prepare Chunk Metadata').map((item) => item.json || {});\nconst chunkItems = $input.all().map((item) => item.json || {});\nconst chunksByFileId = new Map();\n\nfunction driveFileUrl(fileId, existingUrl = '') {\n  if (existingUrl) return existingUrl;\n  if (!fileId || String(fileId).startsWith('unknown_file_')) return '';\n  return `https://drive.google.com/file/d/${fileId}/view`;\n}\n\nfunction plainSheetText(value = '') {\n  return String(value || '').trim() || 'unknown_file_name';\n}\n\nfunction singaporeTimestamp(date = new Date()) {\n  const parts = new Intl.DateTimeFormat(\"en-CA\", {\n    timeZone: \"Asia/Singapore\",\n    year: \"numeric\",\n    month: \"2-digit\",\n    day: \"2-digit\",\n    hour: \"2-digit\",\n    minute: \"2-digit\",\n    second: \"2-digit\",\n    hour12: false\n  }).formatToParts(date).reduce((acc, part) => {\n    if (part.type !== \"literal\") acc[part.type] = part.value;\n    return acc;\n  }, {});\n\n  return parts.year + \"-\" + parts.month + \"-\" + parts.day + \" \" + parts.hour + \":\" + parts.minute + \":\" + parts.second + \" SGT\";\n}\n\nfor (const chunk of chunkItems) {\n  const metadata = chunk.metadata || {};\n  const fileId = metadata.source_file_id || chunk.source_file_id || chunk.file_id;\n  if (!fileId) continue;\n  chunksByFileId.set(fileId, (chunksByFileId.get(fileId) || 0) + 1);\n}\n\nconst uniqueMetadataItems = [];\nconst seenMetadataKeys = new Set();\n\nfor (const metadata of metadataItems) {\n  const fileId = String(metadata.source_file_id || metadata.id || '').trim();\n  const fileName = String(metadata.source_file_name || metadata.name || '').trim().toLowerCase();\n  const key = fileId || fileName;\n\n  if (key && seenMetadataKeys.has(key)) continue;\n  if (key) seenMetadataKeys.add(key);\n\n  uniqueMetadataItems.push(metadata);\n}\n\nreturn uniqueMetadataItems.map((metadata, index) => {\n  const fileId = metadata.source_file_id || metadata.id || `unknown_file_${index + 1}`;\n  const rawFileName = metadata.source_file_name || metadata.name || 'unknown_file_name';\n  const fileUrl = driveFileUrl(fileId, metadata.google_drive_url);\n  let chunksCount = chunksByFileId.get(fileId);\n\n  if (chunksCount === undefined && metadataItems.length === 1) {\n    chunksCount = chunkItems.length;\n  }\n\n  return {\n    json: {\n      file_id: fileId,\n      file_name: plainSheetText(rawFileName),\n      file_url: fileUrl,\n      event_type: metadata.event_type || 'unknown',\n      status: 'completed',\n      chunks_count: chunksCount ?? '',\n      namespace: metadata.namespace || 'SpaceKonceptRental_kb',\n      execution_id: $execution.id,\n      ingested_at: singaporeTimestamp(),\n      error_message: ''\n    }\n  };\n});"
      },
