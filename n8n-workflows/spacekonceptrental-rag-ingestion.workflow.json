      "id": "20000000-0000-4000-8000-000000000015",
      "name": "Resolve Pinecone Index Host",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -16,
        128
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000
    },
    {
      "parameters": {
        "jsCode": "const hostItems = $input.all();\nconst sourceItems = $items('Prepare Chunk Metadata');\n\nreturn hostItems.map((hostItem, index) => {\n  const sourceItem = sourceItems[index] || {};\n  const sourceJson = sourceItem.json || {};\n  const hostJson = hostItem.json?.body || hostItem.json || {};\n  const rawHost = hostJson.host || hostJson.database?.host || '';\n  const host = String(rawHost).replace(/^https?:\\/\\//, '').replace(/\\/$/, '');\n  const namespace = sourceJson.namespace || 'SpaceKonceptRental_kb';\n  const fileId = String(sourceJson.source_file_id || '').trim();\n  const fileName = String(sourceJson.source_file_name || '').trim();\n  const conditions = [];\n\n  if (!host) {\n    throw new Error('Pinecone index host was not returned by Resolve Pinecone Index Host');\n  }\n\n  if (fileId) conditions.push({ source_file_id: { $eq: fileId } });\n  if (fileName) conditions.push({ source_file_name: { $eq: fileName } });\n\n  if (!conditions.length) {\n    throw new Error('Cannot delete stale Pinecone vectors without source_file_id or source_file_name');\n  }\n\n  return {\n    json: {\n      ...sourceJson,\n      pinecone_index_host: host,\n      pinecone_delete_url: `https://${host}/vectors/delete`,\n      pinecone_delete_body: {\n        namespace,\n        filter: conditions.length === 1 ? conditions[0] : { $or: conditions }\n      }\n    },\n    binary: sourceItem.binary\n  };\n});"
      },
