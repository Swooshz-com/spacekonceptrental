              "type": "string"
            },
            {
              "id": "validate-skr-contract-reference-header",
              "name": "enquiry_reference_header",
              "value": "={{ $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-enquiry-reference\"] || \"\" }}",
              "type": "string"
            },
            {
              "id": "validate-skr-contract-idempotency-header",
              "name": "idempotency_key",
              "value": "={{ $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-idempotency-key\"] || \"\" }}",
              "type": "string"
            },
            {
              "id": "validate-skr-contract-timestamp-header",
              "name": "timestamp_header",
              "value": "={{ $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-timestamp\"] || \"\" }}",
              "type": "string"
            },
            {
              "id": "validate-skr-contract-signature-header",
              "name": "signature_header",
              "value": "={{ $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-signature\"] || \"\" }}",
              "type": "string"
            },
            {
              "id": "validate-skr-contract-body-event",
              "name": "payload_event",
              "value": "={{ $(\"Receive SKR Enquiry Handoff\").item.json.body?.event || \"\" }}",
              "type": "string"
            },
            {
              "id": "validate-skr-contract-required-headers",
              "name": "required_headers_present",
              "value": "={{ Boolean($(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-event\"] && $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-enquiry-reference\"] && $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-idempotency-key\"] && $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-timestamp\"] && $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-signature\"]) }}",
              "type": "boolean"
            },
            {
              "id": "validate-skr-contract-event-match",
              "name": "event_matches",
              "value": "={{ $(\"Receive SKR Enquiry Handoff\").item.json.headers?.[\"x-skr-event\"] === \"skr.enquiry.submitted\" && $(\"Receive SKR Enquiry Handoff\").item.json.body?.event === \"skr.enquiry.submitted\" }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
