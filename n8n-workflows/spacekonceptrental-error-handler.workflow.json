      "parameters": {
        "jsCode": "function escapeHtml(value = '') {\n  return String(value || '')\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#39;');\n}\n\nfunction safeSheetValue(value = '') {\n  const text = String(value ?? '');\n  if (!text) return '';\n  if (/^\\+\\s*[\\d()\\-\\s]{3,}$/.test(text)) return text;\n  return /^[=+\\-@]/.test(text) ? \"'\" + text : text;\n}\n\nfunction safeText(value, fallback = 'not_available') {\n  const text = String(value || '').trim() || fallback;\n  return escapeHtml(text);\n}\n\nfunction safeSubjectText(value, fallback = 'not_available', maxLength = 100) {\n  const text = String(value || fallback)\n    .replace(/[\\u0000-\\u001f\\u007f]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n  const safe = text || fallback;\n  return safe.length > maxLength ? safe.slice(0, maxLength - 3).trimEnd() + '...' : safe;\n}\n\nreturn items.map((item) => {\n  const payloadJson = JSON.stringify(item.json);\n\n  return {\n    json: {\n      ...item.json,\n      subject_workflow_name: safeSubjectText(item.json.workflow_name, 'Workflow'),\n      subject_error_type: safeSubjectText(item.json.error_type, 'workflow_failed'),\n      safe_error_time: safeText([item.json.logged_date, item.json.logged_time].filter(Boolean).join(' - ')),\n      safe_contact_id: safeText(item.json.contact_id),\n      safe_workflow_name: safeText(item.json.workflow_name),\n      safe_error_type: safeText(item.json.error_type),\n      safe_error_message: safeText(item.json.error_message),\n      safe_last_node_executed: safeText(item.json.last_node_executed),\n      safe_execution_id: safeText(item.json.execution_id),\n      safe_execution_url: safeText(item.json.execution_url),\n      sheet_logged_date: safeSheetValue(item.json.logged_date),\n      sheet_logged_time: safeSheetValue(item.json.logged_time),\n      sheet_contact_id: safeSheetValue(item.json.contact_id),\n      sheet_error_type: safeSheetValue(item.json.error_type),\n      sheet_error_message: safeSheetValue(item.json.error_message),\n      sheet_workflow_name: safeSheetValue(item.json.workflow_name),\n      sheet_last_node_executed: safeSheetValue(item.json.last_node_executed),\n      sheet_execution_id: safeSheetValue(item.json.execution_id),\n      sheet_execution_url: safeSheetValue(item.json.execution_url),\n      sheet_payload_json: safeSheetValue(payloadJson),\n    },\n  };\n});"
      },
